# Node
node_modules/
.next/
.vercel/
out/
.cache/
*.tsbuildinfo

# Python
__pycache__/
*.pyc
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.venv/
backend/.venv/

# Env (commit only the example)
.env
.env.*
!.env.example

# OS / IDE
.DS_Store
.idea/
.vscode/

# Test output
playwright-report/
test-results/
lighthouse-report.html
frontend/coverage/

# Bundle analyzer output (Stage D)
.next/analyze/

# Claude Code harness — never commit personal/runtime files
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# Terraform local artifacts. Lock files in shared modules are generated by
# local `terraform init -backend=false` for validation; they don't belong in
# version control. Stack roots run through Terragrunt's `.terragrunt-cache/`
# so they don't create lock files in tracked dirs.
**/.terraform/
**/.terragrunt-cache/
terraform/modules/**/.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
